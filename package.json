{
  "name": "ratio-ui",
  "version": "0.0.0",
  "private": true,
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/losol/ratio-ui.git"
  },
  "workspaces": [
    "packages/*",
    "config/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:tag": "changeset tag",
    "clean": "pnpm clean:build && pnpm clean:deps",
    "clean:build": "npx rimraf \"**/{.turbo,dist,storybook-static}\" \"!**/node_modules/**\"",
    "clean:deps": "pnpm -r exec rm -rf node_modules && rm -rf node_modules pnpm-lock.yaml",
    "dev": "pnpm storybook",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "release": "changeset publish",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:mcp": "npx -y storybook@latest mcp --storybook-url http://127.0.0.1:6006",
    "storybook:build": "storybook build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@ratio-ui/eslint-config": "workspace:*",
    "@ratio-ui/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-themes": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.5.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.2",
    "vite": "8.1.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "turbo": "^2.10.2"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=11.0.0"
  }
}
