{
  "name": "@eventuras/ratio-ui",
  "version": "2.15.0",
  "description": "Ratio UI — design system for knowledge sharing",
  "license": "MPL-2.0",
  "homepage": "https://github.com/losol/ratio-ui/tree/main/packages/ratio-ui#readme",
  "bugs": {
    "url": "https://github.com/losol/ratio-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/losol/ratio-ui.git",
    "directory": "packages/ratio-ui"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./core/*": {
      "types": "./dist/core/*/index.d.ts",
      "import": "./dist/core/*/index.js"
    },
    "./layout/*": {
      "types": "./dist/layout/*/index.d.ts",
      "import": "./dist/layout/*/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js"
    },
    "./forms/*": {
      "types": "./dist/forms/*/index.d.ts",
      "import": "./dist/forms/*/index.js"
    },
    "./tree": {
      "types": "./dist/tree/index.d.ts",
      "import": "./dist/tree/index.js"
    },
    "./visuals/*": {
      "types": "./dist/visuals/*/index.d.ts",
      "import": "./dist/visuals/*/index.js"
    },
    "./pages/*": {
      "types": "./dist/pages/*/index.d.ts",
      "import": "./dist/pages/*/index.js"
    },
    "./blocks/*": {
      "types": "./dist/blocks/*/index.d.ts",
      "import": "./dist/blocks/*/index.js"
    },
    "./commerce/*": {
      "types": "./dist/commerce/*/index.d.ts",
      "import": "./dist/commerce/*/index.js"
    },
    "./toast": {
      "types": "./dist/toast/index.d.ts",
      "import": "./dist/toast/index.js"
    },
    "./console": {
      "types": "./dist/console/index.d.ts",
      "import": "./dist/console/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./ratio-ui.css": "./dist/ratio-ui.css",
    "./global.css": "./dist/global.css",
    "./fonts.css": "./src/fonts.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/global.css",
    "src/tokens",
    "src/fonts",
    "src/fonts.css"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "lint": "eslint ."
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react-aria-components": "^1.19.0",
    "react-stately": "^3.48.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@ratio-ui/eslint-config": "workspace:*",
    "@ratio-ui/typescript-config": "workspace:*",
    "@ratio-ui/vite-config": "workspace:*",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint-plugin-storybook": "^10.5.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-react-aria-components": "^2.2.0",
    "typescript": "6.0.3",
    "vite": "8.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
