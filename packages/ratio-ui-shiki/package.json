{
  "name": "@eventuras/ratio-ui-shiki",
  "version": "0.1.0",
  "description": "Alpha — Shiki syntax highlighting for Ratio UI's CodeBlock",
  "license": "MPL-2.0",
  "homepage": "https://github.com/losol/ratio-ui/tree/main/packages/ratio-ui-shiki#readme",
  "bugs": {
    "url": "https://github.com/losol/ratio-ui/issues"
  },
  "repository": {
    "type": "git",
