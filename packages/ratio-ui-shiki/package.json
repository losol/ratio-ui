    "shiki": "^4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.4"
  },
  "peerDependencies": {
    "@eventuras/ratio-ui": "^2.13.0",
    "@shikijs/langs": "^3.0.0",
    "@shikijs/themes": "^3.0.0",
    "shiki": "^4.3.1"
